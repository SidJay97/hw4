<h1><%= @place.name %></h1>

<%= link_to "Back to all places", places_path %>

<% @place.entries.where(user_id: current_user.id).each do |entry| %>
  <h3><%= entry.title %></h3>
  <p><%= entry.occurred_on %></p>
  <p><%= entry.description %></p>
<% end %>

<%= link_to "New Entry", new_place_entry_path(@place) %>
