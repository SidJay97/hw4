<div class="row justify-content-center">
  <div class="col-md-6">
    <h1 class="mb-4">New Place</h1>

    <%= form_with model: @place, local: true do |f| %>
      <div class="mb-3">
        <%= f.label :name %>
        <%= f.text_field :name, class: "form-control" %>
      </div>

      <%= f.submit "Create Place", class: "btn btn-primary" %>
    <% end %>

    <%= link_to "Back", places_path, class: "btn btn-secondary mt-2" %>
  </div>
</div>
